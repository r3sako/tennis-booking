# Local Postgres from docker-compose.yml runs on port 5433.
DATABASE_URL=postgresql+asyncpg://tennis:tennis@localhost:5433/tennis
BOT_TOKEN=
TG_BOT_USERNAME=
SECRET_KEY=change_me_random_string
ADMIN_KEY=
NOTIFY_CHAT_ID=
NOTIFY_NEW_BOOKING=false
# Only members of this chat may log in (residents' group). Empty = open to all.
ALLOWED_CHAT_ID=
# Telegram IDs exempt from the 1-booking-per-day rule (trainer). Comma-separated.
UNLIMITED_USER_IDS=
# Cutover date (YYYY-MM-DD): before it, only dates >= this open, one per day.
# Empty = normal rolling window from today.
BOOKING_OPEN_DATE=
PORT=8000
# Set COOKIE_SECURE=false for local HTTP testing
COOKIE_SECURE=true
# Set DEV_LOGIN=true to enable /auth/dev (login without Telegram). DEV ONLY.
DEV_LOGIN=false
