# Copy to .env on the server and fill in real values.
# docker compose reads this file automatically for ${VAR} substitution.

# Your domain (A-record must point to this server's IP).
DOMAIN=tennis.example.com

# Postgres password (any strong random string; used only inside the box).
POSTGRES_PASSWORD=change_me_strong_password

# App secrets.
SECRET_KEY=change_me_long_random_string
ADMIN_KEY=change_me_admin_key

# Telegram.
BOT_TOKEN=
TG_BOT_USERNAME=
NOTIFY_CHAT_ID=
NOTIFY_NEW_BOOKING=false
# Only members of this chat may log in (residents' group). Bot must be
# a member/admin of it. Usually the same value as NOTIFY_CHAT_ID. Empty = open.
ALLOWED_CHAT_ID=

# Public site URL — shown in the bot's greeting if someone opens it directly.
SITE_URL=https://tennis-khoroshevski.ru
